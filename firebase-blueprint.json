{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User's cognitive identity and system preferences.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "role": { "type": "string" },
        "goals": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "plan": { "type": "string", "enum": ["free", "pro", "max"] },
        "customDirectives": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "role"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation session with the AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "messages": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "messages"]
    },
    "SavedImage": {
      "title": "Saved Image",
      "description": "An image generated by the AI and saved by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "prompt": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "url", "prompt"]
    },
    "Task": {
      "title": "Task",
      "description": "A task in the user's todo list.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "text", "completed", "priority"]
    }
  },
  "firestore": {
    "/users/{userId}/profile/main": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "User's chat sessions"
    },
    "/users/{userId}/images/{imageId}": {
      "schema": "SavedImage",
      "description": "User's saved images"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User's tasks"
    },
    "/users/{userId}/activities/{activityId}": {
      "schema": "object",
      "description": "User activity logs"
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": "Project",
      "description": "User's projects"
    }
  }
}
